# ═══════════════════════════════════════════════════════════════════════════
# Environment template — copy to .env and fill in secrets
# ═══════════════════════════════════════════════════════════════════════════

# Data source: choose "eia" (US, instant key) or "entsoe" (EU, needs approval)
DATA_SOURCE=eia

# ── EIA (United States) ─────────────────────────────────────────────────────
# Free, instant key at https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_key_here

# Balancing Authority — CAL (California), ERCO (Texas), PJM (Mid-Atlantic),
# MISO, NYIS, ISNE, SWPP, US48 (national aggregate)
TARGET_REGION=CAL

# ── ENTSO-E (Europe) ───────────────────────────────────────────────────────
# Request at https://transparency.entsoe.eu/ (may require an email approval)
ENTSOE_API_TOKEN=your_entsoe_token_here
TARGET_COUNTRY=ES

# ── Paths (Delta Lake) ─────────────────────────────────────────────────────
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold

# ── MLflow ─────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=energy-forecasting

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
