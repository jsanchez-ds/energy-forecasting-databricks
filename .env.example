# ENTSO-E Transparency Platform — request free token at https://transparency.entsoe.eu/
ENTSOE_API_TOKEN=your_token_here

# Paths (Delta Lake)
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold

# MLflow
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=energy-forecasting

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Target country (ENTSO-E area code) — examples: ES (Spain), DE_LU (Germany+Lux), FR, IT_NORD
TARGET_COUNTRY=ES
